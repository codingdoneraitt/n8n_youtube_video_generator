# n8n
N8N_IMAGE_TAG=2.19.4
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=replace-with-a-long-random-string
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
GENERIC_TIMEZONE=Europe/Amsterdam

# Postgres
POSTGRES_DB=practice_exam_generator
POSTGRES_USER=practice_exam
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://practice_exam:change-me@postgres:5432/practice_exam_generator

# Renderer
RENDERER_PORT=3030
RENDERER_PUBLIC_BASE_URL=http://localhost:3030
RENDERER_STORAGE_DIR=/data/artifacts
RENDERER_MAX_CONCURRENCY=1
RENDERER_AUTH_TOKEN=
RENDERER_MAX_BODY_BYTES=26214400
RENDER_TIMEOUT_MS=3600000

# External APIs used by n8n workflow credentials or HTTP nodes
TOGETHER_API_KEY=
TOGETHER_TTS_MODEL=hexgrad/Kokoro-82M
TOGETHER_TTS_VOICE=af_bella
TOGETHER_TTS_SPEED=0.95
YOUTUBE_DRY_RUN=true
YOUTUBE_UPLOAD_ENABLED=false
