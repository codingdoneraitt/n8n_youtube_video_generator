{
  "name": "@practice-exam/remotion-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "test": "node --test dist/**/*.test.js",
    "coverage": "node --test --experimental-test-coverage --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=90 --test-coverage-include='dist/props.js' --test-coverage-include='dist/schema.js' --test-coverage-include='dist/tts.js' --test-coverage-exclude='dist/**/*.test.js' dist/**/*.test.js"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/renderer": "^4.0.0",
    "remotion": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@types/react": "^19.0.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
